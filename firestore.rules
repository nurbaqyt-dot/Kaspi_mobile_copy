rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function walletFieldsOnly() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['goldBalance', 'bonusBalance']);
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isOwner(uid) || (signedIn() && walletFieldsOnly());

      match /transactions/{transactionId} {
        allow read: if isOwner(uid);
        allow create: if signedIn();
      }
    }

    match /products/{productId} {
      allow read: if true;
    }

    match /categories/{categoryId} {
      allow read: if true;
    }

    match /cart/{uid}/items/{itemId} {
      allow read, write: if isOwner(uid);
    }

    match /wishlist/{uid}/items/{itemId} {
      allow read, write: if isOwner(uid);
    }

    match /searchHistory/{uid}/queries/{queryId} {
      allow read, write: if isOwner(uid);
    }

    match /viewHistory/{uid}/items/{itemId} {
      allow read, write: if isOwner(uid);
    }

    match /transactions/{uid}/list/{transactionId} {
      allow read, write: if isOwner(uid);
    }

    match /chats/{uid}/messages/{messageId} {
      allow read, write: if isOwner(uid);
    }

    match /orders/{orderId} {
      allow create: if signedIn();
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
